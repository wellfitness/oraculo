{
  "name": "oraculo",
  "version": "1.6.0",
  "description": "Sistema de gestión personal consciente para mujeres +40 que quieren organizarse para cuidarse",
  "type": "module",
  "scripts": {
    "start": "npx http-server dist -p 8000",
    "deploy": "node deploy.mjs",
    "deploy:dry": "node deploy.mjs --dry-run",
    "test": "node --test tests/*.test.js",
    "test:watch": "node --test --watch tests/*.test.js",
    "version": "node scripts/bump-version.mjs",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "sync": "node scripts/sync-dist.mjs",
    "cap:sync": "node scripts/sync-dist.mjs && pnpm exec cap sync",
    "cap:open": "pnpm exec cap open android",
    "cap:run": "pnpm exec cap run android",
    "build:apk": "node scripts/sync-dist.mjs && pnpm exec cap sync && cd android && gradlew assembleDebug",
    "build:aab": "node scripts/sync-dist.mjs && pnpm exec cap sync && cd android && gradlew bundleRelease"
  },
  "devDependencies": {
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "8.3.0",
    "basic-ftp": "^5.0.5",
    "dotenv": "^16.4.5",
    "ws": "8.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wellfitness/oraculo.git"
  },
  "keywords": [
    "productivity",
    "habits",
    "bullet-journal",
    "burkeman",
    "4000-weeks",
    "personal-management",
    "pwa"
  ],
  "author": "Movimiento Funcional <hola@movimientofuncional.com>",
  "license": "CC-BY-NC-SA-4.0",
  "bugs": {
    "url": "https://github.com/wellfitness/oraculo/issues"
  },
  "homepage": "https://oraculo.movimientofuncional.app",
  "dependencies": {
    "@capacitor/android": "8.3.0",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.3.0",
    "@capacitor/local-notifications": "8.0.2",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@codetrix-studio/capacitor-google-auth": "3.4.0-rc.4"
  }
}
